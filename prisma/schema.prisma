generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Link {
  shortCode   String   @id @unique
  originalUrl String
  expireAt   DateTime @default(dbgenerated("(NOW() + '3 years'::interval)"))

  @@map("links")
}
